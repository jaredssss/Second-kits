{
  "manifest_version": 3,
  "name": "Kit – Full Page Screenshot & Annotate",
  "short_name": "Kit Screenshot",
  "version": "1.0.0",
  "description": "Capture full-page screenshots, annotate with arrows/text/shapes, and export as PNG, JPEG, or PDF. Free & premium plans.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Kit Screenshot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://extensionpay.com/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["editor.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "capture-fullpage": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Capture full page screenshot"
    },
    "capture-visible": {
      "suggested_key": { "default": "Alt+Shift+V" },
      "description": "Capture visible area"
    }
  },
  "options_page": "options.html"
}
